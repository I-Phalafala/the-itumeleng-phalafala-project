rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Projects collection: public read, authenticated write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Experience collection: public read, authenticated write
    match /experience/{experienceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Skills collection: public read, authenticated write
    match /skills/{skillId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
