rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Projects collection: public read, admin-only write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Experience collection: public read, admin-only write
    match /experience/{experienceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Skills collection: public read, admin-only write
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
